{
  "manifest_version": 3,
  "name": "Sort YouTube Playlist by Duration",
  "description": "Sort any playlist you own by video length, shortest or longest first, right on the playlist page.",
  "version": "5.0.0",
  "author": "LunarWerx",
  "homepage_url": "https://lunarwerx.com/",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Sort YouTube Playlist by Duration",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "ytsort2.user.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
